# ============================================================
# LLM 配置（支持 OpenAI / Azure OpenAI / Gemini / 本地 Ollama）
# ============================================================

# OpenAI 兼容接口密钥（使用 Ollama 时可留空或填任意值）
OPENAI_API_KEY=sk-your-api-key-here

# 模型名称（如 gpt-4o, gpt-4o-mini, gemini-1.5-pro）
# 使用 OLLAMA_* 时此项会被 OLLAMA_MODEL 覆盖
LLM_MODEL=gpt-4o-mini

# 自定义接口地址（不填则使用 OpenAI 官方地址）
# Azure: https://<resource>.openai.azure.com
# Ollama: http://localhost:11434 或 http://192.168.0.88:8888（兼容 /v1 路径）
# Gemini: https://generativelanguage.googleapis.com/v1beta/openai
LLM_BASE_URL=

# ---------- 使用 Ollama 时可直接配置以下三项（优先于上面 LLM_*）----------
# Ollama 服务地址（填根地址即可，程序会自动加上 /v1，请求 /v1/chat/completions）
OLLAMA_BASE_URL=http://192.168.0.88:8888
# Ollama 模型名
OLLAMA_MODEL=cnshenyang/qwen3-nothink:14b
# Ollama 请求超时（秒），本地大模型可设 180 或更大
OLLAMA_TIMEOUT=180

# LLM 请求超时（毫秒），未设置 OLLAMA_TIMEOUT 时生效
# LLM_TIMEOUT_MS=60000

# ============================================================
# QQPGERP WebAPI 配置
# ============================================================

# ERP API 基础地址（与 qqpgerp-webapi 实际端口一致，如 http://localhost:5801）
ERP_API_BASE_URL=http://localhost:5801

# ERP API 认证 Token：填写 WebAPI 中 AgentApi:Token 的固定值，Agent 请求时带此 Token 即视为已登录
ERP_API_TOKEN=qqpgerp-agent-fixed-token

# ERP 登录信息（可选，用于自动获取 Token）
ERP_LOGIN_USERNAME=
ERP_LOGIN_PASSWORD=

# ============================================================
# Agent 服务配置
# ============================================================

# Agent HTTP 服务端口
PORT=3100

# 日志级别（trace, debug, info, warn, error）
LOG_LEVEL=info

# Agent 单次最大思考步数（防止死循环）
MAX_AGENT_STEPS=10

# 工具调用超时（毫秒）
TOOL_TIMEOUT_MS=30000

# 单个会话至少保留最近 5 轮完整对话；超过后更早内容会自动压缩为摘要
MEMORY_MAX_MESSAGES=10

# 压缩记忆摘要最大字符数
MEMORY_SUMMARY_MAX_CHARS=2000

# ============================================================
# AI 客服 RAG 配置
# ============================================================

# 客服标准话术 docx 路径；默认读取项目根目录上两级的“百问百答7.20（新）.docx”
CUSTOMER_SERVICE_DOCX_PATH=../../百问百答7.20（新）.docx

# RAG 返回候选数量
RAG_TOP_K=3

# 低于该分数时转人工，避免编造客服政策
RAG_MIN_SCORE=0.22

# 当前默认使用本地 hash embedding，后续可替换为独立 embedding 模型
RAG_EMBEDDING_MODEL=local-hash-embedding

# LlamaIndex 本地索引持久化目录
RAG_STORAGE_DIR=./data/customer-service-rag
